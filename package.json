{
  "name": "fantastic-idle-expedition",
  "version": "1.0.0",
  "description": "A browser-based fantasy game.",
  "private": true,
  "scripts": {
    "dev": "esbuild index.tsx --bundle --outfile=index.js --loader:.tsx=tsx --servedir=.",
    "build": "npm run build --prefix backend && esbuild index.tsx --bundle --outfile=dist/index.js --loader:.tsx=tsx --minify && cp index.html dist/index.html"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "esbuild": "^0.17.5",
    "typescript": "^4.9.4"
  }
}